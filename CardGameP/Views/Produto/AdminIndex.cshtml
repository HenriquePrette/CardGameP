@model List<CardGameP.Models.Produto>

@{
    ViewBag.Title = "Gerenciar Produtos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 style="color:#D4AF37;">Gerenciar Produtos</h1>
            <p>Gerencie os produtos cadastrados no sistema</p>
        </div>

        <div>
            <a href="@Url.Action("Create", "Produto")" class="btn btn-gold">
                Novo Produto
            </a>
        </div>
    </div>

    <hr style="border-color: #555;" />

    <div class="product-card mb-4 p-3">
        <h5 class="mb-3" style="color:#D4AF37;">Buscar produto</h5>

        @using (Html.BeginForm("AdminIndex", "Produto", FormMethod.Get))
        {
            <div class="d-flex align-items-center gap-3">
                <input type="text" name="busca"
                       class="form-control search-input search-small"
                       placeholder="Buscar por nome ou jogo..." />

                <button type="submit" class="btn btn-gold btn-small">
                    Buscar
                </button>
            </div>
        }
    </div>

    <div class="product-card p-4">
        <h2 class="mb-3" style="color:#D4AF37;">Lista de Produtos</h2>

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Foto</th>
                        <th>Nome</th>
                        <th>Jogo</th>
                        <th>Raridade</th>
                        <th>Preço</th>
                        <th>Estoque</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.imagem))
                                {
                                    <img src="@Url.Content(item.imagem)" alt="@item.Nome" style="width:50px; height:50px; object-fit:cover; border-radius:10px; border:1px solid #D4AF37;" />
                                }
                                else
                                {
                                    <img src="@Url.Content("~/Content/Image/sem-foto.png")" alt="Sem imagem" style="width:50px; height:50px; object-fit:cover; border-radius:10px; border:1px solid #555;" />
                                }
                            </td>

                            <td>@item.Nome</td>

                            <td>@item.Jogo</td>

                            <td>@item.Raridade</td>

                            <td style="color:#00c26e; font-weight:bold;">R$ @item.Preco.ToString("N2")</td>

                            <td>@item.Estoque</td>

                            <td>
                                <a href="@Url.Action("Edit", "Produto", new { id = item.IdProduto })" class="btn btn-warning btn-sm me-1">Editar</a>
                                <a href="@Url.Action("Delete", "Produto", new { id = item.IdProduto })" class="btn btn-danger btn-sm">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>