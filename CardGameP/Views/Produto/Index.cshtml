@model List<CardGameP.Models.Produto>

@{
    ViewBag.Title = "Produtos";
}

<div class="container mt-4">
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show bg-dark text-danger border-danger mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Erro"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="section-header text-center mb-4">
        <h2 style="color:#D4AF37;">Vitrine de Produtos</h2>
        <p class="text-white-50">Confira os cards disponíveis em nossa loja.</p>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div id="carouselCards" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">

                @{
                    int itensPorSlide = 4;
                    int totalDeCards = Model.Count;
                }

                @for (int i = 0; i < totalDeCards; i += itensPorSlide)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <div class="row justify-content-center">

                            @for (int j = i; j < i + itensPorSlide && j < totalDeCards; j++)
                            {
                                var item = Model[j];

                                <div class="col-md-3 col-sm-6 mb-4">
                                    <div class="product-card p-3" style="border: 1px solid #D4AF37; border-radius: 10px; background-color: #1a1a1a; height: 100%; transition: transform 0.2s;">

                                        <div class="text-center mb-3">
                                            <img src="@Url.Content(!string.IsNullOrEmpty(item.imagem) ? item.imagem : "~/Content/Image/sem-foto.png")"
                                                 alt="@item.Nome"
                                                 class="img-fluid"
                                                 style="max-height: 200px; object-fit: contain; border-radius: 8px;" />
                                        </div>

                                        <div class="text-center text-white">
                                            <h5 style="color: #D4AF37; min-height: 48px;">@item.Nome</h5>
                                            <p class="text-muted mb-1">@item.Jogo</p>
                                            <p class="small mb-2 text-info">Raridade: @item.Raridade</p>
                                            <h4 style="color: #00c26e; font-weight: bold;">R$ @item.Preco.ToString("N2")</h4>

                                            <div class="d-grid gap-2 mt-3">
                                                <a href="@Url.Action("Details", "Produto", new { id = item.IdProduto })"
                                                   class="btn btn-sm btn-outline-light">
                                                    Ver Detalhes
                                                </a>

                                                <a href="@Url.Action("Adicionar", "Carrinho", new { id = item.IdProduto })"
                                                   class="btn btn-sm btn-gold">
                                                    <i class="bi bi-cart-plus"></i> Adicionar ao Carrinho
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#carouselCards" data-bs-slide="prev" style="width: 5%;">
                <span class="carousel-control-prev-icon" aria-hidden="true" style="filter: invert(72%) sepia(54%) saturate(354%) hue-rotate(1deg) brightness(93%) contrast(89%);"></span>
                <span class="visually-hidden">Anterior</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselCards" data-bs-slide="next" style="width: 5%;">
                <span class="carousel-control-next-icon" aria-hidden="true" style="filter: invert(72%) sepia(54%) saturate(354%) hue-rotate(1deg) brightness(93%) contrast(89%);"></span>
                <span class="visually-hidden">Próximo</span>
            </button>
        </div>
    }
    else
    {
        <div class="col-md-12">
            <p class="text-center text-white-50">Nenhum produto encontrado.</p>
        </div>
    }
</div>