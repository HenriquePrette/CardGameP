@model List<CardGameP.Models.Cliente>

@{
    ViewBag.Title = "Gerenciar Clientes";
}

<div class="container mt-4">
    <h1 style="color:#D4AF37;">Gerenciar Clientes</h1>
    <p>Visualize os clientes cadastrados no sistema</p>
    <hr />

    @using (Html.BeginForm("AdminIndex", "Cliente", FormMethod.Get))
    {
        <div class="product-card mb-4">
            <h3>Buscar cliente</h3>
            <div class="row">
                <div class="col-md-8">
                    <input type="text" name="busca" class="form-control search-input"
                           placeholder="Buscar por nome ou email..." />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-gold btn-block">Buscar</button>
                </div>
            </div>
        </div>
    }

    <div class="product-card">
        <h2 style="color:#D4AF37;">Lista de Clientes</h2>

        <table class="table table-dark table-hover">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Telefone</th>
                    <th>Data Cadastro</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nome</td>
                        <td>@item.Email</td>
                        <td>@item.Telefone</td>
                        <td>@item.DataCadastro.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>