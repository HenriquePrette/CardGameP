@model CardGameP.Models.Cliente

@{
    ViewBag.Title = "Entrar - CardGame Store";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div style="width: 100%; max-width: 400px;">

        <div class="product-card p-4" style="border: 1px solid #D4AF37; background-color: #1a1a1a; border-radius: 10px;">

            <div class="text-center mb-4">
                <h2 style="color:#D4AF37;">Login do Cliente</h2>
                <p class="text-white-50">Acesse sua conta para fechar pedidos</p>
            </div>

            @using (Html.BeginForm("Login", "Cliente", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger small mb-3" })

                <div class="mb-3 text-start">
                    <label class="text-white mb-1">E-mail</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control search-input", type = "email", placeholder = "seuemail@exemplo.com", required = "required" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3 text-start">
                    <label class="text-white mb-1">Senha</label>
                    @Html.PasswordFor(m => m.Senha, new { @class = "form-control search-input", placeholder = "Digite sua senha", required = "required" })
                    @Html.ValidationMessageFor(m => m.Senha, "", new { @class = "text-danger small" })
                </div>

                <button type="submit" class="btn btn-gold w-100 mt-3">
                    Entrar
                </button>

                <hr style="border-color: #333;" />

                <div class="text-center mt-3">
                    <span class="text-white-50 small">Não tem uma conta?</span>
                    <br />
                    <a href="@Url.Action("Cadastrar", "Cliente")" style="color: #D4AF37;" class="small text-decoration-none">Cadastre-se aqui.</a>
                </div>
            }
        </div>

    </div>
</div>