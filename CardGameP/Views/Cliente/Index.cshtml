@model IEnumerable<CardGameP.Models.Cliente>

@{
    ViewBag.Title = "Gerenciamento de Clientes";
}

<div class="container mt-4">
    <div class="card shadow-sm border-warning" style="background-color: #1a1a1a; border: 1px solid #D4AF37;">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center" style="border-bottom: 1px solid #D4AF37;">
            <h3 class="mb-0" style="color: #D4AF37;">Painel de Treinadores</h3>
            <a href="@Url.Action("Create", "Cliente")" class="btn btn-gold btn-sm">
                <i class="bi bi-person-plus"></i> + Novo Cliente
            </a>
        </div>

        <div class="card-body text-white">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle border-secondary">
                        <thead class="table-dark text-warning">
                            <tr>
                                <th>ID</th>
                                <th>Nome</th>
                                <th>Email</th>
                                <th>Telefone</th>
                                <th>Cadastro</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-muted">#@item.IdCliente</td>
                                    <td class="fw-bold">@item.Nome</td>
                                    <td>@item.Email</td>
                                    <td>@item.Telefone</td>
                                    <td>@item.DataCadastro.ToShortDateString()</td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <a href="@Url.Action("Edit", "Cliente", new { id = item.IdCliente })" class="btn btn-warning btn-sm" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="@Url.Action("Details", "Cliente", new { id = item.IdCliente })" class="btn btn-info btn-sm text-white" title="Detalhes">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", "Cliente", new { id = item.IdCliente })" class="btn btn-danger btn-sm" title="Excluir">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-dark text-center mb-0 border-secondary">
                    <i class="bi bi-info-circle"></i> Nenhum treinador cadastrado no sistema.
                </div>
            }
        </div>
    </div>
</div>